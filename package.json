{
  "name": "design-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "cli": "bun run packages/cli/src/index.ts",
    "sync-labels": "GITHUB_TOKEN=$npm_config_token bun run .github/scripts/sync-labels.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  }
}
